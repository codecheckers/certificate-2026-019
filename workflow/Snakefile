"""Code checking support workflow

This workflow covers downloading the compressed files, checking those,
and extracting their contents into the required structure. It is not
build to be fail-safe - view it as custom helper.

The workflow is build for Linux machines and may also work on other
UNIX-based systems.

TODO:

- wrap in mktemp ... mv
- pipe output to logs
"""

from pathlib import Path
import os

WORKFLOW_ROOT = Path(workflow.basedir)
REPO_ROOT = WORKFLOW_ROOT.parent

DATAVERSE_BASE_URL = "https://edmond.mpg.de/api/access/datafile"
TOKEN_FILE = WORKFLOW_ROOT / ".env" / "edmond_api_token"

DATA_ROOT = Path("data")
DOWNLOAD_DIR = DATA_ROOT / "downloads"
GOPRO_DIR = DATA_ROOT / "derivatives" / "gopro_derivatives"
WP_DIR = DATA_ROOT / "derivatives" / "wp_derivatives"
METADATA_DIR = DATA_ROOT / "metadata"

CHECKSUM_FILE = DOWNLOAD_DIR / "SCENES_derivatives_SHA256SUMS_v1.0.0.txt"
METADATA_FILE = METADATA_DIR / "SCENES_metadata_v1.0.0.xlsx"
GOPRO_SENTINEL = GOPRO_DIR / ".extracted"
WP_PREP_SENTINEL = WP_DIR / ".extracted"
CHECKSUM_SENTINEL = DOWNLOAD_DIR / ".sha256_checked"

RESULTS_ROOT = Path("results")
WP_DONE_SENTINEL = RESULTS_ROOT / "tables" / "amplitude_spectra_regression_view_df.csv"
SCENES_DONE_SENTINEL = RESULTS_ROOT / "figures" / "Figure_sup.pdf"

CODE_ROOT = REPO_ROOT / "code"
WP_NOTEBOOK = CODE_ROOT / "WP_derivatives.ipynb"
SCENES_NOTEBOOK = CODE_ROOT / "SCENES_spatial_analysis_paper.ipynb"

pathvars:
    logs=str(WORKFLOW_ROOT / "logs"),
    resources=str(WORKFLOW_ROOT / "resources")

FILES = {
