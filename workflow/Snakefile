ARCHIVE_DOWNLOADS = [
    str(entry["download"])
    for entry in FILES.values()
    if "sha256" in entry
]
WP_PARTS = [
    str(FILES[f"wp_{part:03d}"]["download"])
    for part in range(1, 15)
]
DOWNLOAD_TO_ID = {
    str(entry["download"]): entry["id"]
    for entry in FILES.values()
}


def token_command():
    if os.environ.get("EDMOND_API_TOKEN"):
        return "token=\"$EDMOND_API_TOKEN\""
    if TOKEN_FILE.exists() and TOKEN_FILE.read_text().strip():
        return f"token=\"$(cat {TOKEN_FILE})\""
    raise WorkflowError(
        "Missing Edmond API token. Set EDMOND_API_TOKEN or write the token to "
        f"{TOKEN_FILE}."
    )


rule all:
    input:
        str(GOPRO_SENTINEL),
        str(WP_PREP_SENTINEL),
        str(METADATA_FILE)


rule download_file:
    output:
        "{DOWNLOAD_DIR}/{{filename}}"
    params:
        file_id=lambda wildcards, output: DOWNLOAD_TO_ID[output[0]],
        token=token_command()
    shell:
        """
        mkdir -p {DOWNLOAD_DIR}
        {params.token}
        curl -fL --retry 5 \
          -H "X-Dataverse-key: $token" \
          -o {output} \
          {DATAVERSE_BASE_URL}/{params.file_id}
        """


rule verify_archives:
    input:
        checksums=str(CHECKSUM_FILE),
        archives=ARCHIVE_DOWNLOADS
    output:
        touch(str(CHECKSUM_SENTINEL))
    shell:
        """
        cd {DOWNLOAD_DIR}
        sha256sum -c {CHECKSUM_FILE.name}
        """


rule metadata:
    input:
        str(FILES["metadata"]["download"])
    output:
        str(METADATA_FILE)
    shell:
        """
        mkdir -p {METADATA_DIR}
        cp {input} {output}
        """


rule extract_gopro:
    input:
        archive=str(FILES["gopro"]["download"]),
        verified=str(CHECKSUM_SENTINEL)
    output:
        touch(str(GOPRO_SENTINEL))
    shell:
        """
        mkdir -p {GOPRO_DIR}
        7z x -y -o{GOPRO_DIR}/.. {input.archive}  # `/..` not tested
        """


rule extract_wp:
    input:
        first_part=str(FILES["wp_001"]["download"]),
        parts=WP_PARTS,
        verified=str(CHECKSUM_SENTINEL)
    output:
        touch(str(WP_PREP_SENTINEL))
    shell:
        """
        mkdir -p {WP_DIR}
        7z x -y -o{WP_DIR}/.. {input.first_part}  # `/..` not tested
        """


rule run_wp:
    input:
        str(WP_PREP_SENTINEL)
    output:
        str(WP_DONE_SENTINEL)
    conda:
        "envs/notebooks.yml"
    log:
        notebook="<logs>/" + WP_NOTEBOOK.name
    params:
        repo_root=str(REPO_ROOT.resolve()),
        data_dir=str(DATA_ROOT.resolve())
    notebook:
        str(WP_NOTEBOOK)


rule run_scenes:
    input:
        str(GOPRO_SENTINEL),
        str(WP_DONE_SENTINEL)
    output:
        str(SCENES_DONE_SENTINEL)
    conda:
        "envs/notebooks.yml"
    log:
        notebook="<logs>/" + SCENES_NOTEBOOK.name
    params:
        repo_root=str(REPO_ROOT.resolve()),
        data_dir=str(DATA_ROOT.resolve())
    notebook:
        str(SCENES_NOTEBOOK)
